{
  "name": "casa-arquitetura",
  "version": "2.0.0",
  "description": "Casa Arquitetura — Assistente de arquitetura residencial com IA",
  "private": true,
  "packageManager": "pnpm@9.15.0",
  "bin": {
    "aios-graph": "bin/aios-graph.js"
  },
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "lint": "turbo run lint",
    "typecheck": "turbo run typecheck",
    "test": "turbo run test",
    "postinstall": "cd .aios-core && npm install",
    "version:bump": "node scripts/version-bump.js",
    "graph": "node bin/aios-graph.js",
    "entity-registry": "node scripts/generate-entity-registry.js"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/andrewebemp/casa-arquitetura.git"
  },
  "author": "andrewebemp",
  "license": "UNLICENSED",
  "engines": {
    "node": ">=20.0.0"
  },
  "devDependencies": {
    "esbuild": "^0.27.0",
    "supabase": "^2.76.15",
    "turbo": "^2.3.0"
  },
  "dependencies": {
    "asciichart": "^1.5.25"
  }
}
